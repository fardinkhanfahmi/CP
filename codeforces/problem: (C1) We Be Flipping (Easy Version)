vector<ll> si;
void sieve(ll n)
{
    vector<bool> prime(n + 1, true);

    prime[0] = prime[1] = false;

    for(ll i = 2; i * i <= n; i++)
    {
        if(prime[i])
        {
            for(ll j = i * i; j <= n; j += i)
            {
                prime[j] = false;
            }
        }
    }

    for(ll i = 2; i <= n; i++)
    {
        if(prime[i])
        {
            si.push_back(i);
        }
    }
}
ll gcd(ll a, ll b)
{
    while(b)
    {
        ll temp = a % b;
        a = b;
        b = temp;
    }
    return a;
}
ll lcm(ll a, ll b)
{
    return (a / gcd(a, b)) * b;
}
void solve()
{
